# Copy this file to .env before first deployment.
TZ=Asia/Shanghai

MYSQL_PORT=3306
MYSQL_DATABASE=asset_mgm
MYSQL_USER=asset_mgm
MYSQL_PASSWORD=ChangeMe_AssetMgm_Db
MYSQL_ROOT_PASSWORD=ChangeMe_AssetMgm_Root

BACKEND_PORT=8080
FRONTEND_PORT=80

JWT_SECRET=ChangeMe_To_A_Long_Random_Secret_At_Least_32_Chars
JWT_EXPIRATION=86400000

FILE_UPLOAD_PATH=/data/asset-mgm/uploads
JAVA_OPTS=-Xms256m -Xmx1024m